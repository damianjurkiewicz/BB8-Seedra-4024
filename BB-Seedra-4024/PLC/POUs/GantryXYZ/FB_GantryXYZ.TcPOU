    <Method Name="Resetting" Id="{e7a01217-de28-430f-aeef-f83d9f1b6f0d}" FolderPath="States\">
      <Declaration><![CDATA[METHOD PROTECTED Resetting
VAR
	i				: UDINT;
	SubModulesReady : BOOL := TRUE;
END_VAR

VAR_INST
	flagX :BOOL;
	flagY :BOOL;
	flagZ :BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE _CurrentMode OF

    //=================================PRODUCTION MODE==================================
    E_PMLUnitMode.ePMLUnitMode_Production:
        CASE SequenceState OF
            0:
                NoStateTasksToComplete := FALSE;
                SequenceState := 10;

            10:
                AxisX.Enable();
                AxisY.Enable();
                AxisZ.Enable();

                SequenceState := 20;

            20:
                IF AxisX.Enabled AND AxisY.Enabled AND AxisZ.Enabled THEN
                    SequenceState := 30;
                END_IF

            30:

                IF NOT flagX THEN
                    flagX := AxisX.Home();
                END_IF
                IF NOT flagY THEN
                    flagY := AxisY.Home();
                END_IF
                IF NOT flagZ THEN
                    flagZ := AxisZ.Home();
                END_IF


                IF flagX AND flagY AND flagZ THEN
                    flagX := FALSE;
                    flagY := FALSE;
                    flagZ := FALSE;

                    SequenceState := 40; 
                END_IF

            40:
                IF AxisX.Axis.Status.Homed AND AxisY.Axis.Status.Homed AND AxisZ.Axis.Status.Homed THEN

                    flagX := 0;
                    flagY := 0;
                    flagZ := 0;

                    SequenceState := 50;
                END_IF

            50:
                StateTasksComplete := TRUE;
        END_CASE

    //=================================MAINTENANCE & MANUAL MODE==================================
    E_PMLUnitMode.ePMLUnitMode_Maintenance:
        CASE SequenceState OF
            0:
                NoStateTasksToComplete := FALSE;
                SequenceState := 10;

            10:
                AxisX.Enable();
                AxisY.Enable();
                AxisZ.Enable();

                IF AxisX.Enabled AND AxisY.Enabled AND AxisZ.Enabled THEN
                    SequenceState := 20;
                END_IF

            20:
                StateTasksComplete := TRUE;
        END_CASE

    E_PMLUnitMode.ePMLUnitMode_Manual:
        CASE SequenceState OF
            0:
                NoStateTasksToComplete := FALSE;
                SequenceState := 10;

            10:
                AxisX.Enable();
                AxisY.Enable();
                AxisZ.Enable();

                IF AxisX.Enabled AND AxisY.Enabled AND AxisZ.Enabled THEN
                    SequenceState := 20;
                END_IF

            20:
                StateTasksComplete := TRUE;
        END_CASE

END_CASE

SUPER^.Resetting();]]></ST>
      </Implementation>
    </Method>
    <Method Name="StateChanged" Id="{3f8ec15a-7a14-4ca0-a5c1-a685d643ee3a}">
      <Declaration><![CDATA[// Called one Cycle on State Change
METHOD PROTECTED StateChanged
VAR_INPUT
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Wywołujemy kod bazowy frameworka
SUPER^.StateChanged();

// Centralne zarządzanie dynamiką na podstawie nowo osiągniętego stanu maszyny!
CASE _CurrentMode OF
    
    // ==========================================
    // TRYB PRODUKCYJNY
    // ==========================================
    E_PMLUnitMode.ePMLUnitMode_Production:
        CASE _CurrentState OF
            
            E_PMLState.ePMLState_Resetting:
                // W trakcie bazowania osie mają inne limity i spokojnie przyspieszają
                ApplyProfile(E_MachineProfile.eHoming);
                
            E_PMLState.ePMLState_Starting, 
            E_PMLState.ePMLState_Execute:
                // Przed startem lub w trakcie pracy ładujemy agresywny profil produkcyjny
                ApplyProfile(E_MachineProfile.eProduction);
                
            E_PMLState.ePMLState_Aborting:
                // Gdy maszyna wpada w awarię, możemy zapiąć profil z ekstremalnie wysoką Deceleracją!
                ApplyProfile(E_MachineProfile.eProduction); // Albo stworzyć nowy profil eEmergency!
                
        END_CASE
        
    // ==========================================
    // TRYB RĘCZNY / SERWISOWY
    // ==========================================
    E_PMLUnitMode.ePMLUnitMode_Manual, 
    E_PMLUnitMode.ePMLUnitMode_Maintenance:
        
        // Niezależnie od stanu, w trybie ręcznym zawsze blokujemy maszynę w bezpiecznym profilu
        ApplyProfile(E_MachineProfile.eManual);

END_CASE]]></ST>
      </Implementation>
    </Method>
