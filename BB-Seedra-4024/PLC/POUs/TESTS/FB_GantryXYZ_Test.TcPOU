    </Method>
    <Method Name="Test_Speeds_Never_Zero_Or_Negative" Id="{f54ec5ac-644d-440e-a228-c238a39dad40}">
      <Declaration><![CDATA[METHOD Test_Speeds_Never_Zero_Or_Negative
VAR
    BadConfig    : ST_GantryXYZ_Config;
    ActualConfig : ST_GantryXYZ_Config;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('Test_Speeds_Never_Zero_Or_Negative');

// 1. ARRANGE - Złe dane (np. wpisane przez uszkodzone HMI lub błąd ludzki)
BadConfig.RapidSpeedX := 0.0;        // Zero! Oś nigdy nie dojedzie, zawiesi maszynę stanów
BadConfig.CuttingSpeedY := -50.0;    // Ujemna prędkość!
BadConfig.GroovingSpeedZ := -0.01;   // Prędkość zagłębiania bliska 0/ujemna
BadConfig.CuttingIdleTime := -2.0;   // Ujemny czas postoju? Timer zwariuje

// 2. ACT - Próba wstrzyknięcia do Gantry
Gantry.Config := BadConfig;
ActualConfig := Gantry.Config; // Odczytujemy stan po "obronie" przez Set

// 3. ASSERT - Sprawdzamy czy Gantry ustawiło bezpieczne minima
AssertEquals_REAL(Expected := 1.0, 
                  Actual := ActualConfig.RapidSpeedX, 
                  Delta := 0.01, 
                  Message := 'RapidSpeedX rowne 0 zostalo przepuszczone!');

AssertEquals_REAL(Expected := 1.0, 
                  Actual := ActualConfig.CuttingSpeedY, 
                  Delta := 0.01, 
                  Message := 'Ujemna predkosc ciecia przeszla do systemu!');

AssertEquals_REAL(Expected := 1.0, 
                  Actual := ActualConfig.GroovingSpeedZ, 
                  Delta := 0.01, 
                  Message := 'Ujemna/Zerowa predkosc zaglabiania (Z) przeszla!');
                  
AssertEquals_REAL(Expected := 0.0, 
                  Actual := ActualConfig.CuttingIdleTime, 
                  Delta := 0.01, 
                  Message := 'Ujemny czas oczekiwania przeszedl do systemu!');

TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="Test_StateChanged_Updates_Profile" Id="{abb7b416-1445-41ed-9997-c2f59a2f7f59}">
      <Declaration><![CDATA[METHOD Test_StateChanged_Updates_Profile
VAR_INST
    Step : INT := 0;
    Watchdog : TON; // Zabezpieczenie przed zawieszeniem IDE
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('Test_StateChanged_Updates_Profile');

// Krytyczne: Wywołujemy logikę Gantry raz na cykl PLC, BEZ ŻADNYCH PĘTLI WHILE/FOR!
Gantry.CyclicLogic();

// Zabezpieczenie testu: jeżeli maszyna PackML utknie i nie zmieni stanu,
// po 2 sekundach przerywamy test, by chronić IDE przed zawieszeniem.
Watchdog(IN := (Step > 0 AND Step < 100), PT := T#2S);
IF Watchdog.Q THEN
    AssertTrue(Condition := FALSE, Message := 'Timeout testu - PackML utknelo w jednym ze stanow! Prawdopodobnie odrzucono komende.');
    TEST_FINISHED();
    Step := 100; // Blokada przed dalszym wykonywaniem
END_IF

CASE Step OF
    0:
        // 1. Zmieniamy tryb na Manualny (od razu na starcie)
        Gantry.ChangeMode(E_PMLUnitMode.ePMLUnitMode_Manual);
        Step := 5;

    5:
        // Czekamy aż PackML fizycznie "zrozumie" zmianę trybu
        IF Gantry.CurrentMode = E_PMLUnitMode.ePMLUnitMode_Manual THEN
            // Zrzucamy maszynę do bezpiecznego stanu Aborted
            Gantry.ChangeState(E_PMLCommand.ePMLCommand_Abort);
            Step := 10;
        END_IF

    10:
        // Czekamy na wejście w Aborted
        IF Gantry.CurrentState = E_PMLState.ePMLState_Aborted THEN
            
            // W trybie Manual zawsze profil ma być ustawiony na Acc=500.0
            AssertEquals_LREAL(Expected := 500.0, 
                               Actual := Gantry.RefAxisX.Acceleration, 
                               Delta := 0.01, 
                               Message := 'Tryb Manualny nie zaladowal prawidlowego profilu!');

            // Zmieniamy tryb z powrotem na produkcyjny
            Gantry.ChangeMode(E_PMLUnitMode.ePMLUnitMode_Production);
            Step := 15;
        END_IF

    15:
        // Czekamy aż PackML potwierdzi tryb produkcyjny
        IF Gantry.CurrentMode = E_PMLUnitMode.ePMLUnitMode_Production THEN
            // Ze stanu Aborted przechodzimy komendą Clear
            Gantry.ChangeState(E_PMLCommand.ePMLCommand_Clear);
            Step := 20;
        END_IF
        
    20:
        // Maszyna po "Clearing" wejdzie w stan "Stopped"
        IF Gantry.CurrentState = E_PMLState.ePMLState_Stopped THEN
            
            // DOPIERO stąd można bezpiecznie wezwać komendę Reset!
            Gantry.ChangeState(E_PMLCommand.ePMLCommand_Reset);
            Step := 30;
        END_IF

    30:
        // Łapiemy moment wejścia w Resetting
        IF Gantry.CurrentState = E_PMLState.ePMLState_Resetting THEN
            
            // To nasz ostateczny sprawdzian: StateChanged() powinno było podmienić profil!
            AssertEquals_LREAL(Expected := 200.0, 
                               Actual := Gantry.RefAxisX.Acceleration, 
                               Delta := 0.01, 
                               Message := 'Rozpoczecie bazowania (Resetting) nie zmienilo profilu maszyny na Homing!');
                               
            TEST_FINISHED(); // Sukces!
            Step := 100; // Koniec
        END_IF
END_CASE]]></ST>
      </Implementation>
    </Method>
