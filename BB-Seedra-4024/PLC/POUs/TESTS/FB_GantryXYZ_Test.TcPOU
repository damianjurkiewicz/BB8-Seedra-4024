  <POU Name="FB_GantryXYZ_Test" Id="{d7107c61-760f-4794-959d-ee1b05f27712}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_GantryXYZ_Test EXTENDS TcUnit.FB_TestSuite
VAR
	Gantry : FB_GantryXYZ;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[Test_Speeds_Never_Zero_Or_Negative();
]]></ST>
    </Implementation>
    <Method Name="Test_Aborting_Stops_Executors_And_Axes" Id="{9a85fd70-020d-4632-a23d-2731b4b5ff8e}">
      <Declaration><![CDATA[METHOD Test_Aborting_Stops_Executors_And_Axes 

]]></Declaration>
      <Implementation>
        <ST><![CDATA[]]></ST>
      </Implementation>
    </Method>
    <Method Name="Test_ApplyProfile_Applies_Correct_Dynamics" Id="{8083ce83-c327-409b-a072-d96a42a0e0a1}">
      <Declaration><![CDATA[METHOD Test_ApplyProfile_Applies_Correct_Dynamics
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('Test_ApplyProfile_Applies_Correct_Dynamics');

// 1. ACT - Aplikujemy profil Homing (powolny, otwarte limity)
Gantry.ApplyProfile(E_MachineProfile.eHoming);

// 2. ASSERT - Akceleracja osi X powinna wynosić 200.0
AssertEquals_LREAL(Expected := 200.0, 
                   Actual := Gantry.RefAxisX.Acceleration, 
                   Delta := 0.01, 
                   Message := 'ApplyProfile: Blad akceleracji X dla profilu Homing');

// 3. ACT - Aplikujemy profil Production (agresywny)
Gantry.ApplyProfile(E_MachineProfile.eProduction);

// 4. ASSERT - Akceleracja osi X powinna wynosić 1500.0
AssertEquals_LREAL(Expected := 1500.0, 
                   Actual := Gantry.RefAxisX.Acceleration, 
                   Delta := 0.01, 
                   Message := 'ApplyProfile: Blad akceleracji X dla profilu Production');

// 5. ACT - Aplikujemy profil Manual (pośredni)
Gantry.ApplyProfile(E_MachineProfile.eManual);

// 6. ASSERT - Akceleracja osi X powinna wynosić 500.0
AssertEquals_LREAL(Expected := 500.0, 
                   Actual := Gantry.RefAxisX.Acceleration, 
                   Delta := 0.01, 
                   Message := 'ApplyProfile: Blad akceleracji X dla profilu Manual');

TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="Test_Resetting_Initializes_Axes" Id="{2a45b629-3f4f-4690-a9bc-e19fe5313d8e}">
