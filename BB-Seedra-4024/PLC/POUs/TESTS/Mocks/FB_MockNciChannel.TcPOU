<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.15">
  <POU Name="FB_MockNciChannel" Id="{c1b2c3d4-e5f6-4789-9999-000000000010}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_MockNciChannel EXTENDS FB_ComponentBase IMPLEMENTS I_NciChannel_GCode
VAR_INPUT
    MockIsGrouped      : BOOL;
    MockIsProgramLoaded: BOOL;
    MockIsReady        : BOOL;
    MockIsMoving       : BOOL;
    MockChannelError   : BOOL;
    MockChannelErrorId : UDINT;
END_VAR
VAR_OUTPUT
    BuildGroupCallCount : INT;
    LoadProgramCallCount: INT;
    StartCallCount      : INT;
    StopCallCount       : INT;
    UngroupCallCount    : INT;
    ResetCallCount      : INT;
    LoadedProgramPath   : STRING(255);
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
    <Method Name="BuildGroup" Id="{a1b2c3d4-e5f6-4789-9999-000000000011}">
      <Declaration><![CDATA[METHOD BuildGroup]]></Declaration>
      <Implementation>
        <ST><![CDATA[BuildGroupCallCount := BuildGroupCallCount + 1;]]></ST>
      </Implementation>
    </Method>
    <Property Name="ChannelError" Id="{a1b2c3d4-e5f6-4789-9999-000000000012}">
      <Declaration><![CDATA[PROPERTY ChannelError : BOOL]]></Declaration>
      <Get Name="Get" Id="{a1b2c3d4-e5f6-4789-9999-000000000013}">
        <Declaration><![CDATA[]]></Declaration>
        <Implementation>
          <ST><![CDATA[ChannelError := MockChannelError;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="ChannelErrorId" Id="{a1b2c3d4-e5f6-4789-9999-000000000014}">
      <Declaration><![CDATA[PROPERTY ChannelErrorId : UDINT]]></Declaration>
      <Get Name="Get" Id="{a1b2c3d4-e5f6-4789-9999-000000000015}">
        <Declaration><![CDATA[]]></Declaration>
        <Implementation>
          <ST><![CDATA[ChannelErrorId := MockChannelErrorId;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="IsGrouped" Id="{a1b2c3d4-e5f6-4789-9999-000000000016}">
      <Declaration><![CDATA[PROPERTY IsGrouped : BOOL]]></Declaration>
      <Get Name="Get" Id="{a1b2c3d4-e5f6-4789-9999-000000000017}">
        <Declaration><![CDATA[]]></Declaration>
        <Implementation>
          <ST><![CDATA[IsGrouped := MockIsGrouped;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="IsMoving" Id="{a1b2c3d4-e5f6-4789-9999-000000000018}">
      <Declaration><![CDATA[PROPERTY IsMoving : BOOL]]></Declaration>
      <Get Name="Get" Id="{a1b2c3d4-e5f6-4789-9999-000000000019}">
