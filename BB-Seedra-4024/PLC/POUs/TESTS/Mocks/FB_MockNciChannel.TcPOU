        <Implementation>
          <ST><![CDATA[IsMoving := MockIsMoving;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="IsProgramLoaded" Id="{a1b2c3d4-e5f6-4789-9999-000000000020}">
      <Declaration><![CDATA[PROPERTY IsProgramLoaded : BOOL]]></Declaration>
      <Get Name="Get" Id="{a1b2c3d4-e5f6-4789-9999-000000000021}">
        <Declaration><![CDATA[]]></Declaration>
        <Implementation>
          <ST><![CDATA[IsProgramLoaded := MockIsProgramLoaded;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="IsReady" Id="{a1b2c3d4-e5f6-4789-9999-000000000022}">
      <Declaration><![CDATA[PROPERTY IsReady : BOOL]]></Declaration>
      <Get Name="Get" Id="{a1b2c3d4-e5f6-4789-9999-000000000023}">
        <Declaration><![CDATA[]]></Declaration>
        <Implementation>
