    <Method Name="LoadProgram" Id="{a1b2c3d4-e5f6-4789-9999-000000000024}">
      <Declaration><![CDATA[METHOD LoadProgram
VAR_INPUT
    sProgramPath : STRING(255);
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[LoadProgramCallCount := LoadProgramCallCount + 1;
LoadedProgramPath := sProgramPath;]]></ST>
      </Implementation>
    </Method>
    <Method Name="ResetChannel" Id="{a1b2c3d4-e5f6-4789-9999-000000000025}">
      <Declaration><![CDATA[METHOD ResetChannel]]></Declaration>
      <Implementation>
        <ST><![CDATA[ResetCallCount := ResetCallCount + 1;
MockChannelError := FALSE;
MockChannelErrorId := 0;]]></ST>
      </Implementation>
    </Method>
    <Method Name="Start" Id="{a1b2c3d4-e5f6-4789-9999-000000000026}">
      <Declaration><![CDATA[METHOD Start]]></Declaration>
