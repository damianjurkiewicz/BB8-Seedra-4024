    <Declaration><![CDATA[FUNCTION_BLOCK FB_RecipeBase IMPLEMENTS I_RecipeBuilder

VAR
    _Config                 : ST_RecipeBuilder_Config;
    _PanelFrontLength       : REAL;  
    _PanelFrontWidth        : REAL;      
    _PanelHeight            : REAL;    
    _RailHeightCorrection   : REAL;
	
	_Limits : ST_Recipe_Limits;

    // --- NOWE ZMIENNE DO PRZECHOWYWANIA SEGMENTÓW ---
    _SegmentsCutX           : ARRAY [1..32] OF ST_CutSegment;
    _SegmentsCutY           : ARRAY [1..32] OF ST_CutSegment;
    _SegmentsGroove         : ARRAY [1..32] OF ST_CutSegment;
