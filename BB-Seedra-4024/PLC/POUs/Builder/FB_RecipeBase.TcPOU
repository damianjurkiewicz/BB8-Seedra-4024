<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.15">
  <POU Name="FB_RecipeBase" Id="{da96ec31-8163-452f-a094-4558fa21ef5c}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_RecipeBase IMPLEMENTS I_RecipeBuilder 

VAR
    _Config                 : ST_RecipeBuilder_Config;
	_ConfigProvider 		: I_GantryConfigProvider;

	
	
	_Limits : ST_Recipe_Limits;

    // --- NOWE ZMIENNE DO PRZECHOWYWANIA SEGMENTÓW ---
    _SegmentsCutX           : ARRAY [1..32] OF ST_CutSegment;
    _SegmentsCutY           : ARRAY [1..32] OF ST_CutSegment;
    _SegmentsGroove         : ARRAY [1..32] OF ST_CutSegment;
    _SegmentsToCutX         : INT;
    _SegmentsToCutY         : INT;
    _SegmentsToGroove       : INT;
	_FootprintX 			: REAL;
	_FootprintY 			: REAL;
	_MaxCopiesX				: DINT;
	_MaxCopiesY				: DINT;
	_ActualCopiesX			: DINT;
	_ActualCopiesY			: DINT;
	_NominalX 				: REAL;
    _NominalY 				: REAL;
	
	// --- GENERYCZNY GENERATOR G-CODE (NCI) ---
    fbCreateFile    : ItpPpgCreateMain;
    fbAppendLine    : ItpPpgAppendGenericBlock;
    fbCloseFile     : ItpPpgCloseMain;
    
    _aGCodeBuffer   : ARRAY[1..500] OF STRING(255); // Bufor dla Buildera (max 500 linii)
    _nLinesToWrite  : INT;                          // Ile linii z bufora zapisać
    _nFileWriteStep : INT := 0;                     // Krok maszyny stanów zapisu
    _sGCodeFilePath : STRING(255);                  // Ścieżka pliku
	
	
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
