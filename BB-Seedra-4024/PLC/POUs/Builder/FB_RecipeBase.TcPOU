    <Method Name="UpdateNestingLimits" Id="{b78c73fe-7983-4c8d-9c71-a0293b8dccf5}">
      <Declaration><![CDATA[METHOD PUBLIC UpdateNestingLimits
VAR
    MaxOverpass     : REAL;
    MachineConfig   : ST_GantryXYZ_Config; // Zmienna do odczytu offsetu
    EffectiveBoardX : REAL;
    EffectiveBoardY : REAL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// 1. Czysty gabaryt z logiki receptury
THIS^.CalculateFootprint();
MaxOverpass := MAX(_Config.CuttingOverpass, _Config.GroovingOverpass);
_FootprintX := _NominalX + (2.0 * MaxOverpass);
_FootprintY := _NominalY + (2.0 * MaxOverpass);

// 2. Pobranie Global Offsetu ORAZ wymiarów płyty z maszyny
IF _ConfigProvider <> 0 THEN
    MachineConfig := _ConfigProvider.Config;
ELSE
    // Awaryjny "fallback" jeśli Provider nie jest wstrzyknięty (np. w starych testach)
    MachineConfig.GlobalOffsetX := 0.0;
    MachineConfig.GlobalOffsetY := 0.0;
    MachineConfig.RawBoardX := 1220.0; // Domyślna płyta 
    MachineConfig.RawBoardY := 2440.0; // Domyślna płyta
	MachineConfig.RawBoardZ := 9.0;
END_IF

// 3. Efektywna wielkość płyty = Fizyczna płyta (z maszyny) minus offset początkowy
EffectiveBoardX := MachineConfig.RawBoardX - MachineConfig.GlobalOffsetX;
EffectiveBoardY := MachineConfig.RawBoardY - MachineConfig.GlobalOffsetY;

// 4. Przeliczanie kopii nestingu (zabezpieczenie na ujemne wymiary)
IF _FootprintX > 0.0 AND EffectiveBoardX > 0.0 THEN
    _MaxCopiesX := REAL_TO_DINT(TRUNC(EffectiveBoardX / _FootprintX));
ELSE
    _MaxCopiesX := 0;
END_IF

IF _FootprintY > 0.0 AND EffectiveBoardY > 0.0 THEN
    _MaxCopiesY := REAL_TO_DINT(TRUNC(EffectiveBoardY / _FootprintY));
ELSE
    _MaxCopiesY := 0;
END_IF

// =========================================================
// 5. WERYFIKACJA GABARYTÓW (Zabezpieczenie przed za dużym detalem)
// =========================================================
_Config.IsValid := (_MaxCopiesX > 0) AND (_MaxCopiesY > 0) AND (_NominalX > 0) AND (_NominalY > 0);

// =========================================================
// 6. AUTO-KOREKTA KOPII I LIMITÓW DLA HMI
// =========================================================

// ZABEZPIECZENIE Z: Głębokość frezowania nie może przekroczyć grubości płyty!
_Limits.GrooveDepthZ.MaxVal := MachineConfig.RawBoardZ;
// Bezlitosne obcięcie (clamping) wpisanej wartości do nowego limitu
_Config.GrooveDepthZ := LIMIT(_Limits.GrooveDepthZ.MinVal, _Config.GrooveDepthZ, _Limits.GrooveDepthZ.MaxVal);

IF _Config.IsValid THEN
    _Limits.RequestedCopiesX.MinVal := 1.0;
    _Limits.RequestedCopiesX.MaxVal := DINT_TO_REAL(_MaxCopiesX);
    _Limits.RequestedCopiesY.MinVal := 1.0;
    _Limits.RequestedCopiesY.MaxVal := DINT_TO_REAL(_MaxCopiesY);

    IF _Config.FillAll THEN
        _Config.RequestedCopiesX := _MaxCopiesX;
        _Config.RequestedCopiesY := _MaxCopiesY;
    ELSE
        _Config.RequestedCopiesX := LIMIT(1, _Config.RequestedCopiesX, _MaxCopiesX);
        _Config.RequestedCopiesY := LIMIT(1, _Config.RequestedCopiesY, _MaxCopiesY);
    END_IF
ELSE
    // Blokada całkowita jeśli detal się nie mieści
    _Limits.RequestedCopiesX.MinVal := 0.0;
    _Limits.RequestedCopiesX.MaxVal := 0.0;
    _Limits.RequestedCopiesY.MinVal := 0.0;
    _Limits.RequestedCopiesY.MaxVal := 0.0;
    
    _Config.RequestedCopiesX := 0;
    _Config.RequestedCopiesY := 0;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="WriteGCodeFile" Id="{b115e39c-0872-441f-a4ac-20c73a4f870f}">
      <Declaration><![CDATA[METHOD PROTECTED WriteGCodeFile : BOOL
VAR_INPUT
    sFilePath : STRING(255);
END_VAR
VAR_INST
	_iCurrentLine : INT := 1;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[WriteGCodeFile := FALSE;

CASE _nFileWriteStep OF
    0: // INIT
        _iCurrentLine := 1; 
        _sGCodeFilePath := sFilePath;
        
        // LOG: Start operacji - wstawiamy zmienną string w miejsce %s
        ADSLOGSTR(ADSLOG_MSGTYPE_HINT, 'WriteGCode: Rozpoczynam zapis do pliku %s', _sGCodeFilePath);
        
        _nFileWriteStep := 10;

    10: // --- OTWIERANIE/TWORZENIE PLIKU ---
        fbCreateFile(
            bExecute := TRUE, 
            sPathName := _sGCodeFilePath, 
            tTimeOut := T#2S
        );
        
        IF fbCreateFile.bErr THEN 
            // LOG: Błąd tworzenia
            ADSLOGSTR(ADSLOG_MSGTYPE_ERROR, 'WriteGCode: BLAD tworzenia pliku %s!', _sGCodeFilePath);
            _nFileWriteStep := 999;
            
        ELSIF NOT fbCreateFile.bBusy THEN
            fbCreateFile(bExecute := FALSE, sPathName := _sGCodeFilePath);
            
            // LOG: Sukces tworzenia
            ADSLOGSTR(ADSLOG_MSGTYPE_HINT, 'WriteGCode: Plik utworzony pomyslnie, przechodze do zapisu.', '');
            _nFileWriteStep := 20;
        END_IF

    20: // --- ZAPISYWANIE LINII G-CODE W PĘTLI ---
        fbAppendLine(
            bExecute := TRUE, 
            sPathName := _sGCodeFilePath, 
            sBlock := _aGCodeBuffer[_iCurrentLine], 
            tTimeOut := T#2S
        );
        
        IF fbAppendLine.bErr THEN 
            // LOG: Błąd zapisu konkretnej linii
            ADSLOGSTR(ADSLOG_MSGTYPE_ERROR, 'WriteGCode: BLAD dopisywania linii G-Code!', '');
            _nFileWriteStep := 999;
            
        ELSIF NOT fbAppendLine.bBusy THEN
            fbAppendLine(bExecute := FALSE, sPathName := _sGCodeFilePath);
            
            _iCurrentLine := _iCurrentLine + 1;
            IF _iCurrentLine > _nLinesToWrite THEN
                // LOG: Koniec pętli zapisu
                ADSLOGSTR(ADSLOG_MSGTYPE_HINT, 'WriteGCode: Zapisano wszystkie linie G-Code.', '');
                _nFileWriteStep := 30; // Zapisano wszystkie linie
            END_IF
        END_IF

    30: // --- ZAMYKANIE PLIKU ---
        fbCloseFile(
            bExecute := TRUE, 
            sPathName := _sGCodeFilePath, 
            tTimeOut := T#2S
        );
        
        IF fbCloseFile.bErr THEN 
            // LOG: Błąd zamykania
            ADSLOGSTR(ADSLOG_MSGTYPE_ERROR, 'WriteGCode: BLAD zamykania pliku!', '');
            _nFileWriteStep := 999;
            
        ELSIF NOT fbCloseFile.bBusy THEN
            fbCloseFile(bExecute := FALSE, sPathName := _sGCodeFilePath);
            
            // Zapisujemy ścieżkę do struktury Config, żeby Executor NCI wiedział co odpalić
            _Config.GCodePath := _sGCodeFilePath; 
            
            // LOG: Pełny sukces
            ADSLOGSTR(ADSLOG_MSGTYPE_HINT, 'WriteGCode: Plik zamkniety pomyslnie.', '');
            _nFileWriteStep := 1000;
        END_IF

    999: // --- BŁĄD ---
        WriteGCodeFile := FALSE;
        // W tym kroku nie dajemy loga, zeby nie zaspamować konsoli błędem co każdy cykl!
        // Logi błędu wysłaliśmy tuż przed przejściem do kroku 999.

    1000: // --- GOTOWE ---
        _nFileWriteStep := 0; // Reset na przyszłość
        WriteGCodeFile := TRUE;
        
END_CASE]]></ST>
      </Implementation>
    </Method>
