    <Method Name="CalculateFootprint" Id="{b5903cf0-35f3-4a36-9bbd-0a6781b9e2f5}">
      <Declaration><![CDATA[METHOD PROTECTED CalculateFootprint
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Domyślny wymiar detalu (bez dodatków)
_NominalX := _Config.PanelFrontWidth;
_NominalY := _Config.PanelFrontLength;]]></ST>
      </Implementation>
    </Method>
    <Property Name="Config" Id="{cc8b22ea-aed1-438f-8cdd-5e3e5f7b2e90}">
      <Declaration><![CDATA[PROPERTY Config : ST_RecipeBuilder_Config]]></Declaration>
      <Get Name="Get" Id="{51a4be92-27e0-4d30-897e-f466d704a9e2}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[Config := _Config;]]></ST>
        </Implementation>
      </Get>
      <Set Name="Set" Id="{ea17f2c2-4fb3-4cd4-85eb-6bcadc1e2873}">
        <Declaration><![CDATA[VAR
    sTempGCodePath : STRING(255);
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[// 1. NAJPIERW robimy kopię tego co mamy w pamięci sterownika
sTempGCodePath := THIS^._Config.GCodePath; 

// 2. TERAZ przyjmujemy nową strukturę z HMI
_Config := Config;

// 3. PRZYWRACAMY ścieżkę do pliku
_Config.GCodePath := sTempGCodePath;

_Config.PanelFrontLength     := LIMIT(_Limits.PanelFrontLength.MinVal, Config.PanelFrontLength, _Limits.PanelFrontLength.MaxVal);
_Config.PanelFrontWidth      := LIMIT(_Limits.PanelFrontWidth.MinVal,  Config.PanelFrontWidth,  _Limits.PanelFrontWidth.MaxVal);
_Config.PanelHeight          := LIMIT(_Limits.PanelHeight.MinVal,      Config.PanelHeight,      _Limits.PanelHeight.MaxVal);
_Config.RailHeightCorrection := LIMIT(_Limits.RailHeightCorrection.MinVal, Config.RailHeightCorrection, _Limits.RailHeightCorrection.MaxVal);
_Config.GrooveDepthZ		:=	LIMIT(_Limits.GrooveDepthZ.MinVal,	Config.GrooveDepthZ, _Limits.GrooveDepthZ.MaxVal);


THIS^.UpdateNestingLimits();


IF _Config.FillAll THEN
    _Config.RequestedCopiesX := _MaxCopiesX;
    _Config.RequestedCopiesY := _MaxCopiesY;
ELSE
    _Config.RequestedCopiesX := LIMIT(1, _Config.RequestedCopiesX, _MaxCopiesX);
    _Config.RequestedCopiesY := LIMIT(1, _Config.RequestedCopiesY, _MaxCopiesY);
END_IF]]></ST>
        </Implementation>
      </Set>
    </Property>
