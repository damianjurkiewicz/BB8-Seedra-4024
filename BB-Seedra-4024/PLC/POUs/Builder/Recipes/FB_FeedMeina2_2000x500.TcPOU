<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.15">
  <POU Name="FB_FeedMeina2_2000x500" Id="{d0e1f531-1719-47a0-b8ac-19318ae9a8bd}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_FeedMeina2_2000x500 EXTENDS FB_RecipeBase

]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
    <Method Name="Build" Id="{bf3f691a-1696-4f3b-a65f-eadcd135f2c8}">
      <Declaration><![CDATA[METHOD Build : BOOL
VAR
    TotalX, TotalY, Radius : LREAL;
    Velo : LREAL;
    localConfig : ST_GantryXYZ_Config;
	
    // Zmienne do otworów
    HoleDistanceFromEdgeOfRail : LREAL := 100.0;
    SomeFixedDimension         : LREAL := 12.63;
    PanelRailOffsetX           : LREAL;
    PanelRailOffsetY           : LREAL;
    ExtrusionLengthX           : LREAL;
    ExtrusionLengthY           : LREAL;
    
    NumberOfHolesX             : INT := 3;
    NumberOfHolesY             : INT := 5;
    HolesSpacingX              : LREAL;
    HolesSpacingY              : LREAL;
    
    i                          : INT;
    holeIdx                    : INT;
	
	RailSlot  : LREAL := 29.0;
	BigSlot   : LREAL := 200.0;
	SmallSlot : LREAL := 100.0;

// Zmienne pomocnicze do generowania ścieżek
	sx : LREAL;
	sy : LREAL;
	dx : LREAL;
	dy : LREAL;
	r_val : LREAL;
	
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[_Busy := TRUE;
_Done := FALSE;
_Error := FALSE;
Build := FALSE;
THIS^.UpdateNestingLimits();

IF NOT _Config.IsValid THEN
    _Busy := FALSE;
    _Error := TRUE; 
    Build := FALSE;
    RETURN;
END_IF

// ===================================================
// NOWE GEOMETRIE DLA DWÓCH PANELÓW
// ===================================================
// Pojedynczy panel ma teraz szerokość 500 mm, a długość 2000 mm
TotalX := 500.0; 
TotalY := 2000.0; 
Radius := _Config.Radius;

IF Radius > (TotalX / 2.0) THEN Radius := TotalX / 2.0; END_IF
IF Radius > (TotalY / 2.0) THEN Radius := TotalY / 2.0; END_IF

// Przerwa między panelami (2 cm = 20 mm)
PanelGap := 20.0; 

// Offsety dla szyn (zachowujemy oryginalne proporcje 10% wymiaru gabarytowego)
PanelRailOffsetX := 0.1 * TotalX;
PanelRailOffsetY := 0.1 * TotalY;

ExtrusionLengthX := TotalX - (2.0 * PanelRailOffsetX);
ExtrusionLengthY := TotalY - (2.0 * PanelRailOffsetY);

// Wyliczenie rozstawu otworów (dla pojedynczego panelu)
IF NumberOfHolesX > 1 THEN
    HolesSpacingX := (ExtrusionLengthX - (2.0 * HoleDistanceFromEdgeOfRail)) / INT_TO_LREAL(NumberOfHolesX - 1);
ELSE
    HolesSpacingX := 0.0;
END_IF

IF NumberOfHolesY > 1 THEN
    HolesSpacingY := (ExtrusionLengthY - (2.0 * HoleDistanceFromEdgeOfRail)) / INT_TO_LREAL(NumberOfHolesY - 1);
ELSE
    HolesSpacingY := 0.0;
END_IF


// ===================================================
// GENEROWANIE OTWORÓW DLA OBU PANELÓW
// ===================================================
holeIdx := 0; // Startujemy od 0, indeks zwiększany wewnątrz

// Pętla po dwóch panelach (p = 0 dla pierwszego, p = 1 dla drugiego)
FOR p := 0 TO 1 DO
    // Wyznaczamy offset X dla aktualnego panelu (Panel 1: 0.0, Panel 2: 520.0)
    X_Offset := INT_TO_LREAL(p) * (TotalX + PanelGap);

    // 1. Otwór na dokładnym środku danego panelu
    holeIdx := holeIdx + 1;
    _HolesDrill[holeIdx].X := LREAL_TO_REAL((TotalX / 2.0) + X_Offset);
    _HolesDrill[holeIdx].Y := LREAL_TO_REAL(TotalY / 2.0);

    // 2. Rail Y1 (Lewa)
    FOR i := NumberOfHolesY TO 1 BY -1 DO
        holeIdx := holeIdx + 1;
        _HolesDrill[holeIdx].X := LREAL_TO_REAL(PanelRailOffsetX - SomeFixedDimension + X_Offset);
        _HolesDrill[holeIdx].Y := LREAL_TO_REAL(PanelRailOffsetY + HoleDistanceFromEdgeOfRail + ((i - 1) * HolesSpacingY));
    END_FOR

    // 3. Rail X1 (Dolna)
    FOR i := 1 TO NumberOfHolesX DO
        holeIdx := holeIdx + 1;
        _HolesDrill[holeIdx].X := LREAL_TO_REAL(PanelRailOffsetX + HoleDistanceFromEdgeOfRail + ((i - 1) * HolesSpacingX) + X_Offset);
        _HolesDrill[holeIdx].Y := LREAL_TO_REAL(PanelRailOffsetY - SomeFixedDimension);
    END_FOR

    // 4. Rail Y2 (Prawa)
    FOR i := 1 TO NumberOfHolesY DO
        holeIdx := holeIdx + 1;
        _HolesDrill[holeIdx].X := LREAL_TO_REAL(PanelRailOffsetX + ExtrusionLengthX + SomeFixedDimension + X_Offset);
        _HolesDrill[holeIdx].Y := LREAL_TO_REAL(PanelRailOffsetY + HoleDistanceFromEdgeOfRail + ((i - 1) * HolesSpacingY));
    END_FOR

    // 5. Rail X2 (Górna)
    FOR i := NumberOfHolesX TO 1 BY -1 DO
        holeIdx := holeIdx + 1;
        _HolesDrill[holeIdx].X := LREAL_TO_REAL(PanelRailOffsetX + HoleDistanceFromEdgeOfRail + ((i - 1) * HolesSpacingX) + X_Offset);
        _HolesDrill[holeIdx].Y := LREAL_TO_REAL(PanelRailOffsetY + ExtrusionLengthY + SomeFixedDimension);
    END_FOR
END_FOR

// Przypisanie całkowitej liczby otworów z obu paneli
_HolesToDrill := holeIdx;


// ===================================================
// DEFINICJA ILOŚCI I PUNKTÓW STARTOWYCH (Dla FeedTable)
// ===================================================
_ShapesCount := 7; // ZWIĘKSZONO O 1: Teraz mamy 2 główne panele + 5 wycięć z tabeli

// 1. Kształt główny - Panel Lewy
_ShapeStart[1].X := 0.0;
_ShapeStart[1].Y := 0.0;

// 2. Kształt główny - Panel Prawy (szerokość 500 + 20 przerwy)
_ShapeStart[2].X := TotalX + PanelGap; // Czyli 520.0
_ShapeStart[2].Y := 0.0;

// Przesunięcie pozostałych kształtów z tabeli o jeden indeks w górę (były 2..6, są 3..7)
// 3. No. 1
_ShapeStart[3].X := 1030.0;
_ShapeStart[3].Y := 0.0;

// 4. No. 2
_ShapeStart[4].X := 1090.0;
_ShapeStart[4].Y := 0.0;

// 5. No. 3
_ShapeStart[5].X := 210.0;
_ShapeStart[5].Y := 2200.0;

// 6. No. 4
_ShapeStart[6].X := 410.0;
_ShapeStart[6].Y := 2150.0;

// 7. No. 5
_ShapeStart[7].X := 810.0;
_ShapeStart[7].Y := 2150.0;


IF _ConfigProvider <> 0 THEN
    localConfig := _ConfigProvider.Config;
    Velo := localConfig.CuttingSpeedXY;
ELSE
    Velo := 50.0;
END_IF

_GeometryWriter.Clear();
_GeometryWriter.EnableTangentialFollowing();

// Reset zmiennych pomocniczych
sx := 0.0; sy := 0.0; dx := 0.0; dy := 0.0; r_val := 0.0;

// RYSOWANIE KSZTAŁTU ZGODNIE Z INDEKSEM
CASE _CurrentShapeIndex OF
    1, 2:
        // ==========================================
        // KSZTAŁT 1 i 2 (Dwa identyczne panele główne)
        // ==========================================
        // Pobieramy punkt startowy odpowiedni dla Panelu 1 (0,0) lub Panelu 2 (520,0)
        sx := _ShapeStart[_CurrentShapeIndex].X;
        sy := _ShapeStart[_CurrentShapeIndex].Y;

        _GeometryWriter.AddStartPoint(sx, sy);

        // Krawędzie rysowane są z uwzględnieniem punktu startowego 'sx' oraz 'sy'
        _GeometryWriter.AddLine(sx, sy + TotalY - Radius, Velo);
        IF Radius > 0 THEN
            _GeometryWriter.AddArc(sx + Radius, sy + TotalY, sx + Radius, sy + TotalY - Radius, Velo, TRUE);
        END_IF

        _GeometryWriter.AddLine(sx + TotalX - Radius, sy + TotalY, Velo);
        IF Radius > 0 THEN
            _GeometryWriter.AddArc(sx + TotalX, sy + TotalY - Radius, sx + TotalX - Radius, sy + TotalY - Radius, Velo, TRUE);
        END_IF

        _GeometryWriter.AddLine(sx + TotalX, sy + Radius, Velo);
        IF Radius > 0 THEN
            _GeometryWriter.AddArc(sx + TotalX - Radius, sy, sx + TotalX - Radius, sy + Radius, Velo, TRUE);
        END_IF

        _GeometryWriter.AddLine(sx + Radius, sy, Velo);
        IF Radius > 0 THEN
            _GeometryWriter.AddArc(sx, sy + Radius, sx + Radius, sy + Radius, Velo, TRUE);
        END_IF

    3, 4, 5, 6, 7:
        // ==========================================
        // KSZTAŁTY OD 3 DO 7 (Dawne 2 do 6)
        // ==========================================
        sx := _ShapeStart[_CurrentShapeIndex].X;
        sy := _ShapeStart[_CurrentShapeIndex].Y;
        r_val := 10.0;

        // Dopasowanie indeksów warunków (zmniejszone o 1 w stosunku do _CurrentShapeIndex)
        IF _CurrentShapeIndex = 3 THEN
            dx := RailSlot;
            dy := ExtrusionLengthY;
        ELSIF _CurrentShapeIndex = 4 THEN
            dx := RailSlot;
            dy := ExtrusionLengthX; // Uwaga: ExtrusionLengthX bazuje teraz na nowym TotalX (500)
        ELSIF _CurrentShapeIndex = 5 THEN
            dx := SmallSlot;
            dy := SmallSlot;
        ELSIF _CurrentShapeIndex = 6 THEN
            dx := BigSlot;
            dy := BigSlot;
        ELSIF _CurrentShapeIndex = 7 THEN
            dx := BigSlot;
            dy := BigSlot;
        END_IF

        _GeometryWriter.AddStartPoint(sx, sy);

        // 1. Lewa krawędź w górę
        _GeometryWriter.AddLine(sx, sy + dy - r_val, Velo);
        IF r_val > 0 THEN
            _GeometryWriter.AddArc(sx + r_val, sy + dy, sx + r_val, sy + dy - r_val, Velo, TRUE);
        END_IF

        // 2. Górna krawędź w prawo
        _GeometryWriter.AddLine(sx + dx - r_val, sy + dy, Velo);
        IF r_val > 0 THEN
            _GeometryWriter.AddArc(sx + dx, sy + dy - r_val, sx + dx - r_val, sy + dy - r_val, Velo, TRUE);
        END_IF

        // 3. Prawa krawędź w dół
        _GeometryWriter.AddLine(sx + dx, sy + r_val, Velo);
        IF r_val > 0 THEN
            _GeometryWriter.AddArc(sx + dx - r_val, sy, sx + dx - r_val, sy + r_val, Velo, TRUE);
        END_IF

        // 4. Dolna krawędź w lewo i zamknięcie
        _GeometryWriter.AddLine(sx + r_val, sy, Velo);
        IF r_val > 0 THEN
            _GeometryWriter.AddArc(sx, sy + r_val, sx + r_val, sy + r_val, Velo, TRUE);
        END_IF

END_CASE

_GeometryWriter.EndTable();

_Busy := FALSE;
_Done := TRUE;
Build := TRUE;]]></ST>
      </Implementation>
    </Method>
    <Method Name="CalculateFootprint" Id="{1e7e0f86-9dc2-44a5-9e1d-775b513eb599}">
      <Declaration><![CDATA[METHOD PROTECTED CalculateFootprint
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[_NominalX := 1200;
_NominalY := 2400;]]></ST>
      </Implementation>
    </Method>
    <Property Name="ExecutionRoute" Id="{93e0e7a6-1c7f-49f6-a680-ed3aa0192c53}">
      <Declaration><![CDATA[PROPERTY ExecutionRoute : E_ExecutionRoute]]></Declaration>
      <Get Name="Get" Id="{1ed4124b-ff58-4a83-8637-eee22caf6e9a}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[ExecutionRoute := E_ExecutionRoute.eFeedTable;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Method Name="FB_init" Id="{ab0027b3-ed53-49ae-8456-bf761318ee98}">
      <Declaration><![CDATA[METHOD FB_init : BOOL
VAR_INPUT
	bInitRetains : BOOL; // if TRUE, the retain variables are initialized (warm start / cold start)
	bInCopyCode : BOOL;  // if TRUE, the instance afterwards gets moved into the copy code (online change)
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[_Limits.PanelFrontLength.MinVal := 100.0;
_Limits.PanelFrontLength.MaxVal := 2400.0;

_Limits.PanelFrontWidth.MinVal  := 100.0;
_Limits.PanelFrontWidth.MaxVal  := 1200.0;

_Limits.PanelHeight.MinVal      := 0.0;
_Limits.PanelHeight.MaxVal      := 0.0;

_Limits.RailHeightCorrection.MinVal := 0.0;
_Limits.RailHeightCorrection.MaxVal := 0.0;

_Limits.CuttingOverpass.MinVal := 0.0;
_Limits.CuttingOverpass.MaxVal := 50.0;

_Limits.GroovingOverpass.MinVal := 0.0;
_Limits.GroovingOverpass.MaxVal := 50.0;

_Limits.GrooveDepthZ.MinVal := 0.0;
_Limits.GrooveDepthZ.MaxVal := 9.0; 

_Limits.CuttingOverpass.MinVal := 0.0;
_Limits.CuttingOverpass.MaxVal := 50.0;
_Limits.GroovingOverpass.MinVal := 0.0;
_Limits.GroovingOverpass.MaxVal := 50.0;

_Limits.Radius.MinVal := 10.0;     
_Limits.Radius.MaxVal := 600.0;   ]]></ST>
      </Implementation>
    </Method>
