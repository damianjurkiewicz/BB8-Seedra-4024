  <POU Name="FB_ExecutorCutX" Id="{91737efa-f775-4890-9334-f282750ffd75}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_ExecutorCutX EXTENDS FB_ExecutorBase
VAR
    // Zostawiasz tu TYLKO to, co dotyczy bezpośrednio osi X!
    _AxisX          : SPT_Motion_Control.I_BasicAxis;
    _AxisY          : SPT_Motion_Control.I_BasicAxis;
    _AxisZ          : SPT_Motion_Control.I_BasicAxis;
    _Cylinder       : I_Cylinder;                     
    _RecipeBuilder  : I_RecipeBuilder;
    _Config         : REFERENCE TO ST_GantryXYZ_Config;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
