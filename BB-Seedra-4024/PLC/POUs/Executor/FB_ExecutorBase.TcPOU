  <POU Name="FB_ExecutorBase" Id="{0cbe7356-7a09-405e-9aff-39065bb1c2f0}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_ExecutorBase EXTENDS FB_CyclicFB IMPLEMENTS I_MachiningExecutor, I_BB8Specification
VAR
    // Zmienne sekwencyjne 
    nStep           : INT;
    iCurrentSegment : INT;
    StepTimer       : TON;
    _bBusy          : BOOL;
    _bDone          : BOOL;
    _bError         : BOOL;
    _uErrorID       : UDINT;

    // --- ZMIENNE WSPÓLNE DLA WSZYSTKICH EXECUTORÓW
    _AxisX          : SPT_Motion_Control.I_BasicAxis;
    _AxisY          : SPT_Motion_Control.I_BasicAxis;
    _AxisZ          : SPT_Motion_Control.I_BasicAxis;
    _Cylinder       : I_Cylinder;                     
    _RecipeBuilder  : I_RecipeBuilder;
	_ConfigProvider : I_GantryConfigProvider;
	
	iCurrentCopyX : INT := 1;
    iCurrentCopyY : INT := 1;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
    <Method Name="Abort" Id="{6635fc89-ad71-4ff9-bc14-3af14ce8aecc}">
      <Declaration><![CDATA[METHOD Abort
]]></Declaration>
      <Implementation>
        <ST><![CDATA[_bBusy := FALSE;
_bDone := FALSE;
nStep := 0;
iCurrentSegment := 1;
StepTimer(IN := FALSE);]]></ST>
      </Implementation>
    </Method>
