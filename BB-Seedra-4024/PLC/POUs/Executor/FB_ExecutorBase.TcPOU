    nStep           : INT;
    iCurrentSegment : INT;
    StepTimer       : TON;
    
    // Zmienne dla Properties
    _bBusy          : BOOL;
    _bDone          : BOOL;
    _bError         : BOOL;
    _uErrorID       : UDINT;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
    <Method Name="Abort" Id="{6635fc89-ad71-4ff9-bc14-3af14ce8aecc}">
      <Declaration><![CDATA[{warning 'add method implementation '}
METHOD Abort
]]></Declaration>
      <Implementation>
        <ST><![CDATA[_bBusy := FALSE;
_bDone := FALSE;
nStep := 0;
iCurrentSegment := 1;
StepTimer(IN := FALSE);]]></ST>
      </Implementation>
    </Method>
