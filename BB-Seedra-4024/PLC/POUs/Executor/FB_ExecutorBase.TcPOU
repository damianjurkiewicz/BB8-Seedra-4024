    <Method Name="Execute" Id="{c37f539b-c1c9-4761-b6a7-a09dc0c33fb5}">
      <Declaration><![CDATA[{warning 'add method implementation '}
METHOD Execute : BOOL
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF _bBusy THEN RETURN; END_IF

_bBusy    := TRUE;
_bDone    := FALSE;
_bError   := FALSE;
_uErrorID := 0;
nStep     := 5; 
Execute   := TRUE;]]></ST>
      </Implementation>
