    <Method Name="Execute" Id="{c37f539b-c1c9-4761-b6a7-a09dc0c33fb5}">
      <Declaration><![CDATA[METHOD Execute : BOOL
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF _bBusy THEN RETURN; END_IF

_bBusy    := TRUE;
_bDone    := FALSE;
_bError   := FALSE;
_uErrorID := 0;
nStep     := 5; 
iCurrentCopyX := 1; 
iCurrentCopyY := 1; 
Execute   := TRUE;]]></ST>
      </Implementation>
    </Method>
    <Method Name="MoveToXY" Id="{f3cfb8fb-8034-47cd-9b96-9d74f02c4bfe}">
      <Declaration><![CDATA[METHOD PROTECTED MoveToXY 
VAR_INPUT
    TargetX     : REAL; 
    TargetY     : REAL; 
    ToolOffsetX : REAL := 0.0; 
    ToolOffsetY : REAL := 0.0; 
END_VAR
VAR
    localConfig : ST_GantryXYZ_Config;
	NestingOffsetX : REAL;
    NestingOffsetY : REAL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Pobieramy bezpieczną konfigurację z Providera (zawiera GlobalOffset)
localConfig := _ConfigProvider.Config;

// Odejmujemy 1, bo pierwsza kopia (indeks 1) ma offset 0.0
NestingOffsetX := (iCurrentCopyX - 1) * _RecipeBuilder.FootprintX;
NestingOffsetY := (iCurrentCopyY - 1) * _RecipeBuilder.FootprintY;

// I dodajemy to do naszych wspaniałych komend jazdy:
_AxisX.MoveAbsolute(TargetX + ToolOffsetX + NestingOffsetX, 0);
_AxisY.MoveAbsolute(TargetY + ToolOffsetY + NestingOffsetY, 0);



]]></ST>
      </Implementation>
    </Method>
