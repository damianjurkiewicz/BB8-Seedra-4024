<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.15">
  <POU Name="FB_ExecutorGrooveXY" Id="{ba81cf30-ba63-41e2-ba37-7eadadaf4217}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_ExecutorGrooveXY EXTENDS FB_ExecutorBase
]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
    <Method Name="CyclicLogic" Id="{acb188e5-a61c-470f-8c24-c8ec7ab1f0a2}">
      <Declaration><![CDATA[METHOD PUBLIC CyclicLogic
VAR_INST
    // Lokalne zmienne pomocnicze na czas trwania cyklu
    currentSeg          : ST_CutSegment;
    localConfig         : ST_GantryXYZ_Config;
    
    // Zmienne sekwencyjne dla logiki frezowania
    iPass               : INT;
    currentDepth        : LREAL;
    g1, g2, g3, g4, g5  : LREAL;
    v1, v2, v3, v4, v5  : LREAL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[StepTimer();
// Zabezpieczenie na wypadek braku wstrzykniętych referencji!
IF _RecipeBuilder = 0 OR _ConfigProvider = 0 THEN
    RETURN;
END_IF

// Pobieramy konfigurację do pamięci podręcznej 
localConfig := _ConfigProvider.Config;
// Zrzut tablicy segmentów


IF iCurrentSegment < 1 THEN iCurrentSegment := 1; END_IF
IF iCurrentSegment > 32 THEN iCurrentSegment := 32; END_IF

// Wyciągnięcie konkretnego segmentu dla aktualnego kroku
currentSeg := _RecipeBuilder.SegmentsGroove[iCurrentSegment];

CASE nStep OF
    
    0: // IDLE - maszyna czeka na wywołanie Execute()

    // -------- Inicjalizacja procesu --------
    5:
		Trace(Message := CONCAT('WYBRANY PROGRAM: ', TO_STRING(MAIN.Seedra.aRecipeNames[MAIN.Seedra.GantryXYZ.ProgramIdRequested])));
        // Konfiguracja głębokości (g) i mnożników prędkości (v)
        g1 := 3.5; g2 := 3.5; g3 := 1.5; g4 := 0.0; g5 := 0.0;
        v1 := 1.0; v2 := 1.0; v3 := 1.0; v4 := 1.0; v5 := 1.0;

        IF _AxisX.Enable() AND _AxisY.Enable() AND _AxisZ.Enable() THEN
            IF _RecipeBuilder.SegmentsToGroove <= 0 THEN
                //Trace(Message := 'Step 5: Brak segmentow frezowania. Koniec (1000).');
                nStep := 1000;
                RETURN;
            END_IF;
           
            _AxisX.Velocity := localConfig.RapidSpeedX;
            _AxisY.Velocity := localConfig.RapidSpeedY;
            _AxisZ.Velocity := localConfig.RapidSpeedZ;

            iCurrentSegment := 1;
            iPass := 4; // STARTUJEMY OD 1 PRZEJAZDU, tu zmienione do testów, no worries
            
            IF NOT _AxisX.Busy AND NOT _AxisY.Busy AND NOT _AxisZ.Busy THEN
                //Trace(Message := 'Step 5: Start sekwencji frezowania (Grooving).');
                nStep := 10;
            END_IF     
        END_IF

    // -------- Dojazd XY do poczatku (Start) --------
    10:
        //Trace(Message := CONCAT('Step 10: Dojazd XY do START. Segment: ', TO_STRING(iCurrentSegment)));
        //Trace(Message := CONCAT('--- Kopia X: ', TO_STRING(iCurrentCopyX)));
        //Trace(Message := CONCAT('--- Kopia Y: ', TO_STRING(iCurrentCopyY)));
        //Trace(Message := CONCAT('--- Przejazd (Pass): ', TO_STRING(iPass)));
        
        MoveToXY(currentSeg.Start.X, currentSeg.Start.Y, 0.0, 0.0);
        nStep := 20;

    20: // Czekamy na pozycje XY
        IF _AxisX.Error OR _AxisY.Error THEN 
            //Trace(Message := 'Step 20: BLAD OSI X LUB Y!');
            nStep := 999;
        ELSIF _AxisX.InPosition AND _AxisY.InPosition THEN 
            // UWAGA: Tu w przyszłości można odpalić IO.SpindleEnable := TRUE;
            _AxisZ.Velocity := localConfig.GroovingSpeedZ;
            nStep := 30;
        END_IF

    // -------- Wybor glebokosci dla 5 przejsc --------
    30:
        CASE iPass OF
            1: currentDepth := localConfig.GrooveDepthZ - g1;
            2: currentDepth := localConfig.GrooveDepthZ - g2;
            3: currentDepth := localConfig.GrooveDepthZ - g3;
            4: currentDepth := localConfig.GrooveDepthZ - g4;
            5: currentDepth := localConfig.GrooveDepthZ - g5;
        ELSE
            currentDepth := localConfig.GrooveDepthZ;
        END_CASE;

        //Trace(Message := CONCAT('Step 30: Os Z w dol do glebokosci: ', TO_STRING(currentDepth)));
        _AxisZ.MoveAbsolute(currentDepth, 0);
        nStep := 40;

    40: // Czekamy az os Z zjedzie
        IF _AxisZ.Error THEN 
            //Trace(Message := 'Step 40: BLAD OSI Z!');
            nStep := 999;
        ELSIF _AxisZ.InPosition THEN
            // Wybor predkosci posuwu roboczego w zaleznosci od przejscia
            CASE iPass OF
                1: _AxisX.Velocity := localConfig.GroovingSpeedX * v1; _AxisY.Velocity := localConfig.GroovingSpeedY * v1;
                2: _AxisX.Velocity := localConfig.GroovingSpeedX * v2; _AxisY.Velocity := localConfig.GroovingSpeedY * v2;
                3: _AxisX.Velocity := localConfig.GroovingSpeedX * v3; _AxisY.Velocity := localConfig.GroovingSpeedY * v3;
                4: _AxisX.Velocity := localConfig.GroovingSpeedX * v4; _AxisY.Velocity := localConfig.GroovingSpeedY * v4;
                5: _AxisX.Velocity := localConfig.GroovingSpeedX * v5; _AxisY.Velocity := localConfig.GroovingSpeedY * v5;
            END_CASE;
            
            nStep := 50;
        END_IF
            
    50: // Czekanie przed ruchem
        StepTimer(IN := TRUE, PT := REAL_TO_TIME(localConfig.GroovingIdleTime * 1000.0));
        IF StepTimer.Q THEN
            StepTimer(IN := FALSE);
            nStep := 60;
        END_IF

    // -------- Frezowanie do punktu koncowego --------
    60:
        //Trace(Message := CONCAT('Step 60: FREZOWANIE DO STOP. Segment: ', TO_STRING(iCurrentSegment)));
        MoveToXY(currentSeg.Stop.X, currentSeg.Stop.Y, 0.0, 0.0); // ZMIENIONO NA STOP.X i STOP.Y!
        nStep := 70;

    70: // Czekamy na koniec cięcia
        IF _AxisX.Error OR _AxisY.Error OR _AxisZ.Error THEN 
            //Trace(Message := 'Step 70: BLAD OSI podczas frezowania!');
            nStep := 999;
        ELSIF _AxisX.InPosition AND _AxisY.InPosition AND _AxisZ.InPosition THEN
            IF iPass = 5 THEN
                //Trace(Message := 'Step 70: Koniec 5. przejazdu -> Czyszczenie (powrot)');
                nStep := 74;
            ELSE
                //Trace(Message := 'Step 70: Koniec posredniego przejazdu -> Podnoszenie osi Z');
                _AxisZ.Velocity := localConfig.RapidSpeedZ;
                nStep := 80;
            END_IF
        END_IF

    // -------- Procedura czyszcząca na koniec 5-go przejazdu --------
    74:
        StepTimer(IN := TRUE, PT := T#500MS);
        IF StepTimer.Q THEN
            StepTimer(IN := FALSE);
            nStep := 75;
        END_IF

    75: 
        //Trace(Message := 'Step 75: Powrot po sciezce (czyszczenie rowka z Z w dole)');
        MoveToXY(currentSeg.Start.X, currentSeg.Start.Y, 0.0, 0.0); // Tu poprawnie wracamy do START
        nStep := 76;
        
    76: 
        IF _AxisX.Error OR _AxisY.Error THEN 
            nStep := 999;
        ELSIF _AxisX.InPosition AND _AxisY.InPosition THEN
            _AxisZ.Velocity := localConfig.RapidSpeedZ;
            nStep := 80;
        END_IF

    // -------- Podnoszenie osi Z na pozycję bezpieczną --------
    80:
        //Trace(Message := 'Step 80: Podnoszenie osi Z na bezpieczna wysokosc (0)');
        _AxisZ.MoveAbsolute(0, 0);
        nStep := 90;

    90: 
        IF _AxisZ.Error THEN 
            //Trace(Message := 'Step 90: BLAD OSI Z przy podnoszeniu!');
            nStep := 999;
        ELSIF _AxisZ.InPosition THEN
            nStep := 100;
        END_IF  

    100: // Czas stabilizacji po przejsciu
        StepTimer(IN := TRUE, PT := REAL_TO_TIME(localConfig.GroovingIdleTime * 1000.0));
        IF StepTimer.Q THEN
            StepTimer(IN := FALSE);
            // Powrot predkosci X/Y na rapid
            _AxisX.Velocity := localConfig.RapidSpeedX;
            _AxisY.Velocity := localConfig.RapidSpeedY;
            iCurrentSegment := iCurrentSegment + 1;
            
            // Logika zmiany przejazdu / zakonczenia
            IF iCurrentSegment > _RecipeBuilder.SegmentsToGroove THEN
                IF iPass < 5 THEN
                    iPass := iPass + 1;
                    iCurrentSegment := 1;
                    nStep := 10;
                ELSE
                    // =======================================================
                    // CZYSTA PĘTLA NESTINGU (Zrobiono wszystkie 5 passów)
                    // =======================================================
                    //Trace(Message := CONCAT('Step 100: Zrobiono wszystkie segmenty i przejazdy dla kopii. Kopia X: ', TO_STRING(iCurrentCopyX)));
                    
                    iCurrentCopyX := iCurrentCopyX + 1;
                    
                    IF iCurrentCopyX > _RecipeBuilder.ActualCopiesX THEN
                        iCurrentCopyX := 1;
                        iCurrentCopyY := iCurrentCopyY + 1;
                        
                        IF iCurrentCopyY > _RecipeBuilder.ActualCopiesY THEN
                            //Trace(Message := 'Step 100: ZAKONCZONO WSZYSTKIE KOPIE (Groove Nesting gotowy). Skok do 1000.');
                            nStep := 1000;
                        ELSE
                            //Trace(Message := CONCAT('Step 100: Skok do nastepnego rzedu (Kopia Y): ', TO_STRING(iCurrentCopyY)));
                            iPass := 1;
                            iCurrentSegment := 1;
                            nStep := 10;
                        END_IF
                    ELSE
                        //Trace(Message := CONCAT('Step 100: Skok do nastepnego detalu w rzedzie (Kopia X): ', TO_STRING(iCurrentCopyX)));
                        iPass := 1;
                        iCurrentSegment := 1;
                        nStep := 10;
                    END_IF
                END_IF
            ELSE
                nStep := 10;
            END_IF
        END_IF

    999: // Błąd którejkolwiek osi
        //Trace(Message := 'Step 999: FATAL ERROR w GrooveXY - Aborting');
        _bBusy  := FALSE;
        _bError := TRUE; 
        _bDone  := FALSE;
        nStep   := 0;
        
    1000:
        //Trace(Message := 'Step 1000: ZAKONCZONO CALA OPERACJE FREZOWANIA.');
        _bBusy := FALSE;
        _bDone := TRUE;
        nStep := 0;
END_CASE]]></ST>
      </Implementation>
    </Method>
    <LineIds Name="FB_ExecutorGrooveXY">
      <LineId Id="9" Count="0" />
    </LineIds>
    <LineIds Name="FB_ExecutorGrooveXY.CyclicLogic">
      <LineId Id="481" Count="22" />
      <LineId Id="716" Count="0" />
      <LineId Id="504" Count="199" />
      <LineId Id="4" Count="0" />
    </LineIds>
  </POU>
</TcPlcObject>