<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.15">
  <POU Name="FB_Exec_Tangential_FeedTable" Id="{e1b2c3d4-e5f6-4789-9999-000000000040}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_Exec_Tangential_FeedTable EXTENDS FB_ExecutorBase IMPLEMENTS I_GeometryWriter
VAR
    _NciChannel : I_NciChannel_FeedTable;
    _FeedTable  : ST_NciFeedGroupTable; 
    
    // NCI Builder z Tc2_PlcInterpolation
    fbFeedPrep  : FB_NciFeedTablePreparation;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
    <Method Name="Abort" Id="{e1b2c3d4-e5f6-4789-9999-000000000042}">
      <Declaration><![CDATA[METHOD Abort]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF _NciChannel <> 0 THEN
    _NciChannel.Stop();
    _NciChannel.ResetChannel();
    _NciChannel.Ungroup();
END_IF
_bBusy := FALSE; _bDone := FALSE; _bError := FALSE; _uErrorID := 0; nStep := 0;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddArc" Id="{af788716-9307-40d3-8fa3-1e39a3e2ad04}">
      <Declaration><![CDATA[METHOD AddArc : BOOL
VAR_INPUT
    TargetX    : LREAL;
    TargetY    : LREAL;
    CenterX    : LREAL;
    CenterY    : LREAL;
    Velo       : LREAL;
    Clockwise  : BOOL; 
END_VAR

VAR
    stArc : ST_NciGeoCirclePlane;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[stArc.fEndPosX := TargetX;
stArc.fEndPosY := TargetY;
stArc.fEndPosZ := 0.0;
stArc.fCenterX := CenterX;
stArc.fCenterY := CenterY;
stArc.fCenterZ := 0.0;
stArc.fVelo := Velo;
stArc.bClockwise := Clockwise;
stArc.nPlane := E_NciGeoPlane.E_NciGeoPlaneXY;

fbFeedPrep(
    nEntryType := E_NciEntryType.E_NciEntryTypeGeoCirclePlane,
    pEntry := ADR(stArc),
    bResetTable := FALSE,
    bResetAll := FALSE,
    stFeedGroupTable := _FeedTable
);
AddArc := NOT fbFeedPrep.bError;]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddLine" Id="{de37e77a-59fa-4e4f-b465-dfe20df19cd8}">
      <Declaration><![CDATA[METHOD AddLine : BOOL
VAR_INPUT
    TargetX : LREAL;
    TargetY : LREAL;
    Velo    : LREAL;
END_VAR

VAR
    stLine : ST_NciGeoLine;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[

stLine.fEndPosX := TargetX;
stLine.fEndPosY := TargetY;
stLine.fEndPosZ := 0.0;
stLine.fVelo := Velo;

fbFeedPrep(
    nEntryType := E_NciEntryType.E_NciEntryTypeGeoLine,
    pEntry := ADR(stLine),
    bResetTable := FALSE,
    bResetAll := FALSE,
    stFeedGroupTable := _FeedTable
);
AddLine := NOT fbFeedPrep.bError;]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddStartPoint" Id="{55a012b2-5afc-4c4d-8025-2901f3448d7b}">
      <Declaration><![CDATA[METHOD AddStartPoint : BOOL
VAR_INPUT
    TargetX : LREAL;
    TargetY : LREAL;
END_VAR
VAR
    stStart : ST_NciGeoStart;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[stStart.fPosX := TargetX;
stStart.fPosY := TargetY;
stStart.fPosZ := 0.0;

fbFeedPrep(
    nEntryType := E_NciEntryType.E_NciEntryTypeGeoStart,
    pEntry := ADR(stStart),
    bResetTable := FALSE,
    bResetAll := FALSE,
    stFeedGroupTable := _FeedTable
);
AddStartPoint := NOT fbFeedPrep.bError;]]></ST>
      </Implementation>
    </Method>
    <Method Name="Clear" Id="{ce1afe41-d722-4a51-b756-4addb08a67f1}">
      <Declaration><![CDATA[METHOD Clear : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[fbFeedPrep(
    nEntryType := E_NciEntryType.E_NciEntryTypeNone,
    pEntry := 0,
    bResetTable := TRUE,
    bResetAll := TRUE, // Czyści też modale i błędy (wg str. 315)
    stFeedGroupTable := _FeedTable
);
Clear := NOT fbFeedPrep.bError;]]></ST>
      </Implementation>
    </Method>
    <Method Name="CyclicLogic" Id="{e1b2c3d4-e5f6-4789-9999-000000000041}">
      <Declaration><![CDATA[METHOD PUBLIC CyclicLogic
VAR_INST
    localConfig   : ST_GantryXYZ_Config;
    recipeConfig  : ST_RecipeBuilder_Config;
    MaterialTopZ  : REAL;
    SafeZ         : REAL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[SUPER^.CyclicLogic();

IF nStep > 0 THEN
    IF _RecipeBuilder = 0 OR _ConfigProvider = 0 OR _NciChannel = 0 THEN
        ADSLOGSTR(ADSLOG_MSGTYPE_ERROR, 'ExecTangential: BŁĄD - Brak wymaganych referencji!', '');
        nStep := 999;
    END_IF
END_IF

CASE nStep OF
    0: // IDLE

    5: // INIT

        IF _AxisX.Enable() AND _AxisY.Enable() AND _AxisZ.Enable() AND _AxisQ.Enable() THEN
            
         
            IF _AxisX.Enabled AND _AxisY.Enabled AND _AxisZ.Enabled AND _AxisQ.Enabled 
               AND NOT _AxisX.Busy AND NOT _AxisY.Busy AND NOT _AxisQ.Busy THEN
                
                ADSLOGSTR(ADSLOG_MSGTYPE_HINT, 'ExecTangential: Osie gotowe. Rozpoczynam sekwencję Nestingu.', '');
                _bBusy := TRUE;
                localConfig := _ConfigProvider.Config;
                recipeConfig := _RecipeBuilder.Config;

                IF NOT recipeConfig.IsValid THEN
                    ADSLOGSTR(ADSLOG_MSGTYPE_ERROR, 'ExecTangential: Receptura nieprawidłowa (IsValid=FALSE)!', '');
                    nStep := 1000;
                    RETURN;
                END_IF

                iCurrentCopyX := 1;
                iCurrentCopyY := 1;

                _AxisX.Velocity := localConfig.RapidSpeedX;
                _AxisY.Velocity := localConfig.RapidSpeedY;
                _AxisZ.Velocity := localConfig.RapidSpeedZ;

                nStep := 8;
            END_IF
        END_IF

    8: 
        ADSLOGSTR(ADSLOG_MSGTYPE_HINT, 'ExecTangential: Dojazd PTP do punktu startowego NCI.', '');
        MoveToXY(recipeConfig.NciStartX, recipeConfig.NciStartY, 0.0, 0.0);
		_AxisQ.MoveAbsolute(0.0, 0);
        nStep := 9;

    9: 
        IF _AxisX.Error OR _AxisY.Error OR _AxisZ.Error OR _AxisQ.Error THEN
            nStep := 999;
        ELSIF _AxisX.InPosition AND _AxisY.InPosition AND _AxisQ.InPosition THEN
            localConfig := _ConfigProvider.Config;
            MaterialTopZ := localConfig.GlobalOffsetZ + localConfig.RawBoardZ;
            SafeZ := MaterialTopZ + localConfig.SafeClearanceZ;

            ADSLOGSTR(ADSLOG_MSGTYPE_HINT, 'ExecTangential: Punkt startowy osiągnięty. Ustawiam oś Z na pozycję bezpieczną.', '');
            _AxisZ.MoveAbsolute(SafeZ, 0);
            nStep := 10;
        END_IF

    10: 
        IF _AxisZ.Error THEN
            nStep := 999;
        ELSIF _AxisZ.InPosition THEN
            nStep := 20;
        END_IF

    20: 
        ADSLOGSTR(ADSLOG_MSGTYPE_HINT, 'ExecTangential: Budowanie grupy NCI (X,Y,Z,Q).', '');
        _NciChannel.BuildGroup();
        nStep := 30;

    30: 
        IF _NciChannel.ChannelError THEN
            nStep := 999;
        ELSIF _NciChannel.IsGrouped THEN
            ADSLOGSTR(ADSLOG_MSGTYPE_HINT, 'ExecTangential: Grupa zbudowana. Start podawania punktów (FeedTable).', '');
            _NciChannel.StartFeedTable(stTable := THIS^._FeedTable); 
            nStep := 40;
        END_IF

    40: 
        IF _NciChannel.ChannelError THEN
            nStep := 999;
        ELSIF _NciChannel.IsFeedingDone THEN
            ADSLOGSTR(ADSLOG_MSGTYPE_HINT, 'ExecTangential: Tabela przesłana do NC. Czekam na koniec ruchu.', '');
            nStep := 50;
        END_IF

    50: 
        IF _NciChannel.ChannelError THEN
            nStep := 999;
        ELSIF _NciChannel.IsChannelDone THEN
            ADSLOGSTR(ADSLOG_MSGTYPE_HINT, 'ExecTangential: Ruch NCI zakończony. Resetowanie kanału.', '');
            _NciChannel.ResetChannel();
            nStep := 80;
        END_IF

    80: 
        _NciChannel.Ungroup();
        nStep := 90;

    90: 
        IF NOT _NciChannel.IsGrouped THEN
            nStep := 110; 
        END_IF

    110:
        iCurrentCopyX := iCurrentCopyX + 1;
        IF iCurrentCopyX > _RecipeBuilder.ActualCopiesX THEN
            iCurrentCopyX := 1;
            iCurrentCopyY := iCurrentCopyY + 1;
            IF iCurrentCopyY > _RecipeBuilder.ActualCopiesY THEN
                nStep := 1000;
            ELSE
                ADSLOGSTR(ADSLOG_MSGTYPE_HINT, 'ExecTangential: Rozpoczynam kolejny rząd (Y) kopii.', '');
                nStep := 8;
            END_IF
        ELSE
            ADSLOGSTR(ADSLOG_MSGTYPE_HINT, 'ExecTangential: Rozpoczynam kolejną kopię w rzędzie (X).', '');
            nStep := 8;
        END_IF

    999: 
        _bBusy := FALSE;
        _bError := TRUE;
        _bDone := FALSE;
        _uErrorID := _NciChannel.ChannelErrorId;
        ADSLOGDINT(ADSLOG_MSGTYPE_ERROR, 'ExecTangential: BŁĄD KRYTYCZNY! ErrorID: %d', UDINT_TO_DINT(_uErrorID));
        _NciChannel.Ungroup();
        nStep := 0;

    1000: 
        ADSLOGSTR(ADSLOG_MSGTYPE_HINT, 'ExecTangential: Wszystkie operacje zakończone sukcesem.', '');
        _bBusy := FALSE;
        _bDone := TRUE;
        nStep := 0;
END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="EnableTangentialFollowing" Id="{d2004b92-6a97-4549-b0d7-74a42dd1632f}">
      <Declaration><![CDATA[METHOD EnableTangentialFollowing : BOOL
VAR
    stTf : ST_NciTangentialFollowingDesc;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[stTf.bTangOn := TRUE;
stTf.nTangAxis := E_NciAxesInGroup.Q1Axis;
stTf.nPathAxis1 := E_NciAxesInGroup.XAxis;
stTf.nPathAxis2 := E_NciAxesInGroup.YAxis;
stTf.fOffset := 0.0;
stTf.fCriticalAngle1 := 90.0; 
stTf.nTfBehavior := E_TangentialFollowingBehavior.E_TfIngoreAll; // Uwaga na literówkę Beckhoffa!

fbFeedPrep(
    nEntryType := E_NciEntryType.E_NciEntryTypeTfDesc,
    pEntry := ADR(stTf),
    bResetTable := FALSE,
    bResetAll := FALSE,
    stFeedGroupTable := _FeedTable
);
EnableTangentialFollowing := NOT fbFeedPrep.bError;]]></ST>
      </Implementation>
    </Method>
    <Method Name="EndTable" Id="{65428bc6-7970-4afa-a4f2-edf109d35f22}">
      <Declaration><![CDATA[METHOD EndTable : BOOL
VAR
    stEnd : ST_NciEndOfTables;
END_VAR

]]></Declaration>
      <Implementation>
        <ST><![CDATA[
fbFeedPrep(
    nEntryType := E_NciEntryType.E_NciEntryTypeEndOfTables,
    pEntry := ADR(stEnd),
    bResetTable := FALSE,
    bResetAll := FALSE,
    stFeedGroupTable := _FeedTable
);
EndTable := NOT fbFeedPrep.bError;]]></ST>
      </Implementation>
    </Method>
    <Property Name="NciChannel" Id="{e1b2c3d4-e5f6-4789-9999-000000000043}">
      <Declaration><![CDATA[PROPERTY NciChannel : I_NciChannel_FeedTable]]></Declaration>
      <Get Name="Get" Id="{e1b2c3d4-e5f6-4789-9999-000000000044}">
        <Declaration><![CDATA[]]></Declaration>
        <Implementation>
          <ST><![CDATA[NciChannel := _NciChannel;]]></ST>
        </Implementation>
      </Get>
      <Set Name="Set" Id="{e1b2c3d4-e5f6-4789-9999-000000000045}">
        <Declaration><![CDATA[]]></Declaration>
        <Implementation>
          <ST><![CDATA[_NciChannel := NciChannel;]]></ST>
        </Implementation>
      </Set>
    </Property>
