  <POU Name="FB_ExecutorCutY" Id="{dd6d66cd-f173-4abb-82a1-2cfe699de1cb}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_ExecutorCutY EXTENDS FB_ExecutorBase IMPLEMENTS I_BB8Specification
VAR
    
    _AxisX          : SPT_Motion_Control.I_BasicAxis; 
    _AxisY          : SPT_Motion_Control.I_BasicAxis; 
    _AxisZ          : SPT_Motion_Control.I_BasicAxis; 
    _Cylinder       : I_Cylinder;                     
    _RecipeBuilder  : I_RecipeBuilder;              
    _Config         : REFERENCE TO ST_GantryXYZ_Config; 
    
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
