    <Method Name="CyclicLogic" Id="{bcb376a0-0151-4d63-8ae8-dc8bbce88220}">
      <Declaration><![CDATA[METHOD PUBLIC CyclicLogic
VAR_INST
    // Lokalna kopia segmentów dla zachowania spójności danych w cyklu
    localSegmentsCutY : ARRAY[1..32] OF ST_CutSegment;
    currentSeg        : ST_CutSegment;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[

// Aktualizacja timera krokowege
StepTimer();

// 1. Zabezpieczenie przed brakiem referencji (Dependency Injection)
IF _RecipeBuilder = 0 OR NOT __ISVALIDREF(_Config) THEN
    Trace('Brak referencji w ExecutorCutY!');
    RETURN;
END_IF

// 2. Kopiowanie danych przepisu do pamięci lokalnej
localSegmentsCutY := _RecipeBuilder.SegmentsCutY;

// Kontrola zakresu indeksu segmentu
IF iCurrentSegment < 1 THEN iCurrentSegment := 1; END_IF
IF iCurrentSegment > 32 THEN iCurrentSegment := 32; END_IF

// Pobranie danych aktualnie przetwarzanego segmentu
currentSeg := localSegmentsCutY[iCurrentSegment];

CASE nStep OF
    0: // IDLE - oczekiwanie na wywołanie Execute() przez Orchestrator
        
    // -------- Inicjalizacja procesu --------
    5:
        IF _AxisX.Enable() AND _AxisY.Enable() AND _AxisZ.Enable() THEN
            Trace('SegmentExecutionY Started');

            IF _RecipeBuilder.SegmentsToCutY <= 0 THEN
                // Brak danych do obróbki - natychmiastowe zakończenie
                nStep := 1000;
                RETURN;
            END_IF;

            // Nastawy dynamiki pobrane z globalnej konfiguracji maszyny
            _AxisX.Acceleration := 500;  _AxisX.Deceleration := 8000;
            _AxisY.Acceleration := 500;  _AxisY.Deceleration := 8000;
            _AxisZ.Acceleration := 500;  _AxisZ.Deceleration := 8000;
            
            // Prędkość dojazdowa (Rapid)
            _AxisX.Velocity := _Config.RapidSpeedX;
            _AxisY.Velocity := _Config.RapidSpeedY;
            _AxisZ.Velocity := _Config.RapidSpeedZ;

            iCurrentSegment := 1;
            
            IF NOT _AxisX.Busy AND NOT _AxisY.Busy AND NOT _AxisZ.Busy THEN
                nStep := 10;
            END_IF     
        END_IF

    // -------- Dojazd do punktu START segmentu --------
    10:
        _AxisX.MoveAbsolute(
            currentSeg.Start.X + _Config.CutterYOffsetX + _Config.GlobalOffset, 
            0);
        _AxisY.MoveAbsolute(
            currentSeg.Start.Y + _Config.CutterYOffsetY + _Config.GlobalOffset, 
            0);
        nStep := 20;

    20: // Oczekiwanie na osiągnięcie pozycji XY
        IF _AxisX.InPosition AND _AxisY.InPosition THEN 
            nStep := 30;
        END_IF

    // -------- Aktywacja narzędzia (Ostrze Y w dół) --------
    30:
        _Cylinder.Extend();
        nStep := 40;

    40: 
        IF _Cylinder.Extended THEN
            // Zmiana prędkości na roboczą (Cutting Speed)
            _AxisX.Velocity := _Config.CuttingSpeedX;
            _AxisY.Velocity := _Config.CuttingSpeedY;
            nStep := 50;
        END_IF
            
    50: // Czas stabilizacji przed cięciem
        StepTimer(IN := TRUE, PT := REAL_TO_TIME(_Config.CuttingIdleTime * 1000.0));
        IF StepTimer.Q THEN
            StepTimer(IN := FALSE);
            nStep := 60;
        END_IF

    // -------- Ruch roboczy do punktu STOP segmentu --------
    60:
        _AxisX.MoveAbsolute(
            currentSeg.Stop.X + _Config.CutterYOffsetX + _Config.GlobalOffset, 
            0);
        _AxisY.MoveAbsolute(
            currentSeg.Stop.Y + _Config.CutterYOffsetY + _Config.GlobalOffset, 
            0);
        nStep := 70;

    70: // Oczekiwanie na zakończenie ruchu roboczego
        IF _AxisX.InPosition AND _AxisY.InPosition THEN
            nStep := 80;
        END_IF

    // -------- Dezaktywacja narzędzia i inkrementacja segmentu --------
    80:
        _Cylinder.Retract();
        nStep := 85;

    85: 
        IF _Cylinder.Retracted THEN
             iCurrentSegment := iCurrentSegment + 1;
             nStep := 90;
        END_IF    

    90: // Drugi Idle Time i decyzja o kontynuacji
        StepTimer(IN := TRUE, PT := REAL_TO_TIME(_Config.CuttingIdleTime * 1000.0));
        IF StepTimer.Q THEN
            StepTimer(IN := FALSE);
            
            // Powrót do prędkości Rapid przed kolejnym dojazdem
            _AxisX.Velocity := _Config.RapidSpeedX;
            _AxisY.Velocity := _Config.RapidSpeedY;
            
            IF iCurrentSegment > _RecipeBuilder.SegmentsToCutY THEN
                nStep := 1000; // Wszystkie segmenty wykonane
            ELSE
                nStep := 10;   // Skok do początku kolejnego odcinka
            END_IF
        END_IF

    // -------- Finalizacja pracy --------
    1000:
        Trace('SegmentExecutionY-FINISHED');
        _bBusy := FALSE; // Zwolnienie flagi Busy z FB_ExecutorBase
        _bDone := TRUE;  // Ustawienie flagi Done dla Orchestratora
        nStep := 0;      // Powrót do IDLE
        
END_CASE]]></ST>
      </Implementation>
    </Method>
